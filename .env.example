# Gmail Configuration
# Apna Gmail address yahan likhein
GMAIL_EMAIL=your_email@gmail.com

# Gmail App Password (not regular password)
# Kaise banayein: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=your_16_digit_app_password

# ==========================================
# WhatsApp (Twilio) Configuration
# ==========================================
# Twilio Account SID (Twilio Dashboard se milega)
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token (Twilio Dashboard se milega)
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio WhatsApp Number (Sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Customer WhatsApp Number (with country code, e.g., +923143504308)
CUSTOMER_WHATSAPP_NUMBER=+923143504308
